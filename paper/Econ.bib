  author = {Squartini, Tiziano and Garlaschelli, Diego},
  date = {2011-08-03},
  journaltitle = {New Journal of Physics},
  shortjournal = {New J. Phys.},
  volume = {13},
  number = {8},
  eprint = {1103.0701},
