  author = {Dorninger, Christian and Hornborg, Alf and Abson, David J. and family=Wehrden, given=Henrik, prefix=von, useprefix=true and Schaffartzik, Anke and Giljum, Stefan and Engler, John-Oliver and Feller, Robert L. and Hubacek, Klaus and Wieland, Hanspeter},
