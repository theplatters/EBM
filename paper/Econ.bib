@article{stegmayerInstitutFuerPolitikwissenschaft,
  title = {Institut für Politikwissenschaft und Sozialpolitik},
  author = {Stégmayer, Márk},
  abstract = {Die vorliegende Arbeit untersucht die Rolle von antifeministischen und antigenderistischen Narrativen in rechtspopulistischen Parteien aus Österreich und Deutschland. Ausgehend von theoretischen Konzepten zu (Rechts)Populismus, Rechtsextremismus, Antifeminismus und Antigenderismus wird analysiert, wie Begriffe wie „Gender-Ideologie“ oder „Gender-Wahn“ als Instrument dienen, um gesellschaftliche Konflikte zu verschärfen und eine breite Wählergruppe anzusprechen. Besondere Aufmerksamkeit gilt dabei der Funktion des Genderdiskurses als „symbolischer Klebstoff“, der heterogene politische und ideologische Strömungen verbindet. Empirisch werden Wahl- und Grundsatzprogramme von FPÖ, ÖVP, AfD und CDU untersucht. Die Ergebnisse zeigen, dass zwar Unterschiede in der Radikalität bestehen, die inhaltliche Richtung aber häufig übereinstimmt: Populistische Parteien konstruieren oft Genderthemen und Feminismus als Bedrohung für die „Normalität“ der traditionellen Familie und nationalen Kultur. Diese Rhetorik trägt zu Abwertung gleichstellungspolitischer Errungenschaften bei und stabilisiert zugleich rechte Allianzen, die sich gegen progressive gesellschaftliche Entwicklungen richten.},
  langid = {german},
  file = {/home/franzs/Zotero/storage/Q2XCIH96/Stégmayer - Institut für Politikwissenschaft und Sozialpolitik.pdf}
}

@article{steiningerAustriasConsumptionbasedGreenhouse2018,
  title = {Austria’s Consumption-Based Greenhouse Gas Emissions: {{Identifying}} Sectoral Sources and Destinations},
  shorttitle = {Austria’s Consumption-Based Greenhouse Gas Emissions},
  author = {Steininger, Karl W. and Munoz, Pablo and Karstensen, Jonas and Peters, Glen P. and Strohmaier, Rita and Velázquez, Erick},
  date = {2018-01-01},
  journaltitle = {Global Environmental Change},
  shortjournal = {Global Environmental Change},
  volume = {48},
  pages = {226--242},
  issn = {0959-3780},
  doi = {10.1016/j.gloenvcha.2017.11.011},
  url = {https://www.sciencedirect.com/science/article/pii/S0959378017304508},
  urldate = {2025-05-08},
  abstract = {Greenhouse gas emissions can be addressed at the points of both production and consumption of goods and services. In a world of inhomogeneous climate policy, missing out policies on either production or consumption leaves an important policy area idle, rendering climate policy inefficient and potentially ineffective. While consumption-based emissions accounts have become readily available at the national level, we here show how their more detailed analysis by sectoral destination (which final demand sectors account for them), sectoral source (in which sectors across the globe those emissions are actually occurring) and the geographical location of the latter can inform a complementary consumption-based climate policy approach. For the example of the EU member country Austria, we find that more than 60\% of its consumption-based emissions occur outside its borders, and 34\% even outside the EU. The top sectors are a very different list under a consumption-based accounting perspective (construction, public administration (including defense, health and education), and wholesale and retail trade) than under a production-based one (electricity, iron and steel, and non-metallic minerals, such as cement). While for some sectors (e.g. electricity) production-based approaches can work well, emission reduction in other sectors (e.g. electronic equipment) is crucially dependent on consumption-based approaches, as a structural path analysis reveals.},
  keywords = {Border carbon adjustment,Border tax adjustment,Climate policy,Consumption-based accounting,Effective policy,Efficient policy,Embodied emissions,Emission intensity,Greenhouse gas,Greenhouse gas accounting,International trade,Labels,Leakage,National determined contributions,Sector emissions,Sector policy,Structural path analysis,Unilateral policy,Value chain,Virtual carbon},
  file = {/home/franzs/Zotero/storage/4X6X36W9/Steininger et al. - 2018 - Austria’s consumption-based greenhouse gas emissions Identifying sectoral sources and destinations.pdf;/home/franzs/Zotero/storage/TCL6L7SR/S0959378017304508.html}
}

