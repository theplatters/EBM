  shorttitle = {Stochastic Perturbations to Dynamical Systems},
  author = {Lucarini, Valerio},
  date = {2012-02},
  journaltitle = {Journal of Statistical Physics},
  shortjournal = {J Stat Phys},
  volume = {146},
